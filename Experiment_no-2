{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"toc_visible":true,"authorship_tag":"ABX9TyPa2ZCGOrwYxrjpzun1T676"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n","\n","# Input data\n","X_original = np.array([1, 2, 3]) # Renamed to avoid conflict with X_bias\n","Y1 = np.array([2, 4, 6])\n","Y2 = np.array([3, 5, 7])\n","\n","# Design matrix (adding bias term)\n","X_bias = np.column_stack((np.ones(len(X_original)),X_original))\n","Y = np.column_stack((Y1,Y2))\n","# Matrix factorization (Normal Equation)\n","# W = (XᵀX)^(-1) Xᵀy\n","W = np.linalg.inv(X_bias.T @ X_bias) @ X_bias.T @ Y\n","W = np.round(W).astype(int)\n","# Extract coefficients\n","b1=W[0][0]\n","b2=W[0][1]\n","w1=W[1][0]\n","w2=W[1][1]\n","print(\"Regression Equation for Y1:\")\n","print(f\"Y1 = {b1} + {w1}X\")\n","print(\"Regression Equation for Y2:\")\n","print(f\"Y2 = {b2} + {w2}X\")\n","\n","# Predictions\n","Y_pred = X_bias @ W\n","Y1_pred = Y_pred[:, 0]\n","Y2_pred = Y_pred[:, 1]\n","\n","print(\"\\nPredicted Y1-values:\")\n","print(Y1_pred)\n","print(\"\\nPredicted Y2-values:\")\n","print(Y2_pred)\n","\n","# Performance metrics\n","\n","# Metrics for Y1\n","mae1 = mean_absolute_error(Y1, Y1_pred)\n","mse1 = mean_squared_error(Y1, Y1_pred)\n","rmse1 = np.sqrt(mse1)\n","sse1 = np.sum((Y1 - Y1_pred)**2)\n","r2_1 = r2_score(Y1, Y1_pred)\n","\n","# Calculate Adjusted R-squared for Y1\n","n = len(Y1) # Number of observations\n","p = X_bias.shape[1] - 1 # Number of predictors (excluding the intercept)\n","\n","if (n - p - 1) > 0:\n","    adjusted_r_squared_1 = 1 - (1 - r2_1) * ((n - 1) / (n - p - 1))\n","else:\n","    adjusted_r_squared_1 = np.nan # Or handle as appropriate for the data size\n","\n","print(\"\\nPerformance Metrics for Y1:\")\n","print(f\"MAE  : {mae1:.4f}\")\n","print(f\"MSE  : {mse1:.4f}\")\n","print(f\"RMSE : {rmse1:.4f}\")\n","print(f\"SSE  : {sse1:.4f}\")\n","print(f\"R²   : {r2_1:.4f}\")\n","print(f\"Adj R² : {adjusted_r_squared_1:.4f}\")\n","\n","# Metrics for Y2\n","mae2 = mean_absolute_error(Y2, Y2_pred)\n","mse2 = mean_squared_error(Y2, Y2_pred)\n","rmse2 = np.sqrt(mse2)\n","sse2 = np.sum((Y2 - Y2_pred)**2)\n","r2_2 = r2_score(Y2, Y2_pred)\n","\n","# Calculate Adjusted R-squared for Y2\n","# n and p are the same for Y2 as for Y1\n","if (n - p - 1) > 0:\n","    adjusted_r_squared_2 = 1 - (1 - r2_2) * ((n - 1) / (n - p - 1))\n","else:\n","    adjusted_r_squared_2 = np.nan # Or handle as appropriate for the data size\n","\n","print(\"\\nPerformance Metrics for Y2:\")\n","print(f\"MAE  : {mae2:.4f}\")\n","print(f\"MSE  : {mse2:.4f}\")\n","print(f\"RMSE : {rmse2:.4f}\")\n","print(f\"SSE  : {sse2:.4f}\")\n","print(f\"R²   : {r2_2:.4f}\")\n","print(f\"Adj R² : {adjusted_r_squared_2:.4f}\")\n","\n","# -------------------- PLOTS --------------------\n","\n","# Plot 1: Actual vs Predicted for Y1\n","plt.figure(figsize=(8, 6))\n","plt.scatter(Y1, Y1_pred, color='blue', s=100, label='Actual Data Points', zorder=2)\n","plt.plot([min(Y1), max(Y1)], [min(Y1), max(Y1)], 'r--', label='Perfect Prediction', zorder=1)\n","plt.xlabel(\"Actual Values Y1\")\n","plt.ylabel(\"Predicted Values Y1\")\n","plt.title(\"Actual vs Predicted Data for Y1\")\n","plt.grid(True)\n","plt.legend()\n","plt.show()\n","\n","# Plot 2: Actual vs Predicted for Y2\n","plt.figure(figsize=(8, 6))\n","plt.scatter(Y2, Y2_pred, color='green', s=100, label='Actual Data Points', zorder=2)\n","plt.plot([min(Y2), max(Y2)], [min(Y2), max(Y2)], 'r--', label='Perfect Prediction', zorder=1)\n","plt.xlabel(\"Actual Values Y2\")\n","plt.ylabel(\"Predicted Values Y2\")\n","plt.title(\"Actual vs Predicted Data forz Y2\")\n","plt.grid(True)\n","plt.legend()\n","plt.show()\n","\n","# Plot 3: Error Metrics (combined bar graph for Y1 and Y2)\n","metrics_names = ['MAE', 'MSE', 'RMSE', 'R-squared', 'Adj R-squared']\n","metrics_values_y1 = [mae1, mse1, rmse1, r2_1, adjusted_r_squared_1]\n","metrics_values_y2 = [mae2, mse2, rmse2, r2_2, adjusted_r_squared_2]\n","\n","x = np.arange(len(metrics_names))\n","width = 0.35\n","\n","fig, ax = plt.subplots(figsize=(12, 7))\n","rects1 = ax.bar(x - width/2, metrics_values_y1, width, label='Y1', color='skyblue')\n","rects2 = ax.bar(x + width/2, metrics_values_y2, width, label='Y2', color='lightcoral')\n","\n","ax.set_ylabel('Value')\n","ax.set_title('Regression Model Error Metrics for Y1 and Y2')\n","ax.set_xticks(x)\n","ax.set_xticklabels(metrics_names, rotation=45, ha='right')\n","ax.legend()\n","ax.grid(axis='y', linestyle='--', alpha=0.7)\n","plt.tight_layout()\n","plt.show()\n","plt.savefig(\"exp-3\")"],"metadata":{"id":"QyoFqc1Y89kt","executionInfo":{"status":"ok","timestamp":1769950796049,"user_tz":-330,"elapsed":5449,"user":{"displayName":"24CSEAIML089 ANUBHAB PANDA","userId":"16870966920088987141"}},"outputId":"32dd460c-9078-4907-cd28-111c225c4d26","colab":{"base_uri":"https://localhost:8080/","height":1000}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Regression Equation for Y1:\n","Y1 = 0 + 2X\n","Regression Equation for Y2:\n","Y2 = 1 + 2X\n","\n","Predicted Y1-values:\n","[2. 4. 6.]\n","\n","Predicted Y2-values:\n","[3. 5. 7.]\n","\n","Performance Metrics for Y1:\n","MAE  : 0.0000\n","MSE  : 0.0000\n","RMSE : 0.0000\n","SSE  : 0.0000\n","R²   : 1.0000\n","Adj R² : 1.0000\n","\n","Performance Metrics for Y2:\n","MAE  : 0.0000\n","MSE  : 0.0000\n","RMSE : 0.0000\n","SSE  : 0.0000\n","R²   : 1.0000\n","Adj R² : 1.0000\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x700 wit